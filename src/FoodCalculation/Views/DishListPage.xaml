<Page x:Class="FoodCalculation.Views.DishListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DishListPage">

    <Grid>

        <Grid.Background>
            <LinearGradientBrush>
                <GradientStop Color="#001a4a" Offset="0"/>
                <GradientStop Color="#006ba9" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Page title -->
        <Label
            Grid.Row="0"
            Grid.Column="1"
            Grid.ColumnSpan="3"
            Content="Gerichte"
            Margin="20,0"
            FontSize="40"
            Foreground="White"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            FontWeight="Bold"
            x:Name="PageTitle"/>

        <!-- Back button: returns to main window -->
        <Button
            Grid.Row="0"
            Grid.Column="4"
            Margin="20"
            Background="#a1000000"
            Content="Zurueck"
            FontSize="20"
            Foreground="White"
            Click="BackButton_Click"
            x:Name="BackButton">
            <Button.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <ThicknessAnimation Storyboard.TargetName="BackButton" Storyboard.TargetProperty="Margin" To="15" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetName="BackButton" Storyboard.TargetProperty="FontSize" By="2" Duration="0:0:0.2" FillBehavior="HoldEnd"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <ThicknessAnimation Storyboard.TargetName="BackButton" Storyboard.TargetProperty="Margin" To="20" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetName="BackButton" Storyboard.TargetProperty="FontSize" By="-2" Duration="0:0:0.2" FillBehavior="Stop"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Button.Triggers>
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="25">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Refresh button -->
        <Button
            Grid.Row="0"
            Grid.Column="0"
            Margin="20"
            Background="#a1000000"
            Content="Refresh"
            FontSize="20"
            Click="RefreshButton_Click"
            Foreground="White"
            x:Name="RefreshButton">
            <Button.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <ThicknessAnimation Storyboard.TargetName="RefreshButton" Storyboard.TargetProperty="Margin" To="15" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetName="RefreshButton" Storyboard.TargetProperty="FontSize" By="2" Duration="0:0:0.2" FillBehavior="HoldEnd"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <ThicknessAnimation Storyboard.TargetName="RefreshButton" Storyboard.TargetProperty="Margin" To="20" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetName="RefreshButton" Storyboard.TargetProperty="FontSize" By="-2" Duration="0:0:0.2" FillBehavior="Stop"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Button.Triggers>
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="25">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Add dish button -->
        <Button
            Grid.Row="0"
            Grid.Column="3"
            Margin="20"
            Content="Hinzufuegen"
            Click="AddButton_Click"
            Foreground="White"
            Background="#a1000000"
            x:Name="AddButton">
            <Button.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <ThicknessAnimation Storyboard.TargetName="AddButton" Storyboard.TargetProperty="Margin" To="15" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetName="AddButton" Storyboard.TargetProperty="FontSize" By="2" Duration="0:0:0.2" FillBehavior="HoldEnd"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <ThicknessAnimation Storyboard.TargetName="AddButton" Storyboard.TargetProperty="Margin" To="20" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetName="AddButton" Storyboard.TargetProperty="FontSize" By="-2" Duration="0:0:0.2" FillBehavior="Stop"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Button.Triggers>
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="25">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Filter button -->
        <Button
            Grid.Row="0"
            Grid.Column="1"
            Margin="20"
            Content="Filter"
            Foreground="White"
            Background="#a1000000"
            FontSize="20"
            Click="FilterButton_Click"
            x:Name="FilterButton">
            <Button.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <ThicknessAnimation Storyboard.TargetName="FilterButton" Storyboard.TargetProperty="Margin" To="15" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetName="FilterButton" Storyboard.TargetProperty="FontSize" By="2" Duration="0:0:0.2" FillBehavior="HoldEnd"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <ThicknessAnimation Storyboard.TargetName="FilterButton" Storyboard.TargetProperty="Margin" To="20" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetName="FilterButton" Storyboard.TargetProperty="FontSize" By="-2" Duration="0:0:0.2" FillBehavior="Stop"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Button.Triggers>
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="20">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Scrollable dish list -->
        <Border
            Grid.Row="1"
            Grid.ColumnSpan="5"
            Margin="25"
            Background="#a1000000"
            CornerRadius="30">
            <ScrollViewer
                VerticalScrollBarVisibility="Auto"
                Background="Transparent"
                x:Name="DishScrollViewer">
                <StackPanel x:Name="DishStackPanel"/>
            </ScrollViewer>
        </Border>

    </Grid>
</Page>
