<Window x:Class="FoodCalculation.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Grid x:Name="LayoutRoot">

        <Grid.Background>
            <LinearGradientBrush>
                <GradientStop Color="#006ba9" Offset="0"/>
                <GradientStop Color="#001a4a" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="267*"/>
            <ColumnDefinition Width="267*"/>
            <ColumnDefinition Width="215*"/>
            <ColumnDefinition Width="52*"/>
        </Grid.ColumnDefinitions>

        <!-- Title label -->
        <Label
            Grid.Row="0"
            Grid.ColumnSpan="4"
            x:Name="PageTitle"
            FontWeight="Bold"
            Content="Kalkulation"
            VerticalContentAlignment="Center"
            HorizontalContentAlignment="Center"
            Margin="20,0"
            FontSize="50"
            Foreground="White"/>

        <!-- Button: navigate to dish list -->
        <Button Content="Gerichte"
                Click="GerichteButton_Click"
                Grid.ColumnSpan="2"
                Grid.Row="1"
                FontSize="{Binding ElementName=ZutatenButton, Path=FontSize}"
                Foreground="White"
                x:Name="GerichteButton"
                Margin="30">
            <Button.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <ThicknessAnimation
                                Storyboard.TargetName="GerichteButton"
                                Storyboard.TargetProperty="Margin"
                                To="20"
                                Duration="0:0:0.2"/>
                            <DoubleAnimation
                                Storyboard.TargetName="GerichteButton"
                                Storyboard.TargetProperty="FontSize"
                                By="3"
                                Duration="0:0:0.2"
                                FillBehavior="HoldEnd"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <ThicknessAnimation
                                Storyboard.TargetName="GerichteButton"
                                Storyboard.TargetProperty="Margin"
                                To="30"
                                Duration="0:0:0.2"/>
                            <DoubleAnimation
                                Storyboard.TargetName="GerichteButton"
                                Storyboard.TargetProperty="FontSize"
                                By="-3"
                                Duration="0:0:0.2"
                                FillBehavior="Stop"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Button.Triggers>
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border
                        Background="#a7000000"
                        CornerRadius="25"
                        Padding="10">
                        <TextBlock
                            Text="Gerichte"
                            Foreground="White"
                            TextAlignment="Center"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            FontSize="{TemplateBinding FontSize}"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Button: navigate to ingredients overview -->
        <Button
            Content="Zutaten"
            Click="ZutatenButton_Click"
            FontSize="30"
            Grid.Column="2"
            Grid.ColumnSpan="2"
            Grid.Row="1"
            Margin="30"
            Foreground="White"
            x:Name="ZutatenButton">
            <Button.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <ThicknessAnimation
                                Storyboard.TargetName="ZutatenButton"
                                Storyboard.TargetProperty="Margin"
                                To="20"
                                Duration="0:0:0.2"/>
                            <DoubleAnimation
                                Storyboard.TargetName="ZutatenButton"
                                Storyboard.TargetProperty="FontSize"
                                By="3"
                                Duration="0:0:0.2"
                                FillBehavior="HoldEnd"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <ThicknessAnimation
                                Storyboard.TargetName="ZutatenButton"
                                Storyboard.TargetProperty="Margin"
                                To="30"
                                Duration="0:0:0.2"/>
                            <DoubleAnimation
                                Storyboard.TargetName="ZutatenButton"
                                Storyboard.TargetProperty="FontSize"
                                By="-3"
                                Duration="0:0:0.2"
                                FillBehavior="Stop"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Button.Triggers>
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border
                        Background="#a7000000"
                        CornerRadius="25"
                        Padding="10">
                        <TextBlock
                            Text="Zutaten"
                            Foreground="White"
                            TextAlignment="Center"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            FontSize="{TemplateBinding FontSize}"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Frame for page navigation (overlays the entire window) -->
        <Frame
            Grid.RowSpan="2"
            Grid.ColumnSpan="4"
            x:Name="MainFrame"
            NavigationUIVisibility="Hidden"/>

    </Grid>
</Window>
