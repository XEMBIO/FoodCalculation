<Page x:Class="FoodCalculation.Views.MyIngredientsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MyIngredientsPage">

    <Grid>

        <Grid.Background>
            <LinearGradientBrush>
                <GradientStop Color="#006ba9" Offset="0"/>
                <GradientStop Color="#001a4a" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Page title -->
        <Label
            Grid.Row="0"
            Grid.Column="1"
            Content="Meine Zutaten"
            Margin="20,0"
            FontSize="40"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            FontWeight="Bold"
            Foreground="White"
            x:Name="PageTitle"/>

        <!-- Back button -->
        <Button
            Grid.Column="2"
            Grid.Row="0"
            Margin="20"
            Content="Zurueck"
            Click="BackButton_Click"
            FontSize="20"
            x:Name="BackButton">
            <Button.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <ThicknessAnimation Storyboard.TargetName="BackButton" Storyboard.TargetProperty="Margin" To="15" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetName="BackButton" Storyboard.TargetProperty="FontSize" By="2" Duration="0:0:0.2" FillBehavior="HoldEnd"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <ThicknessAnimation Storyboard.TargetName="BackButton" Storyboard.TargetProperty="Margin" To="20" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetName="BackButton" Storyboard.TargetProperty="FontSize" By="-2" Duration="0:0:0.2" FillBehavior="Stop"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Button.Triggers>
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="#a1000000" CornerRadius="25">
                        <TextBlock
                            Text="Zurueck"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Padding="10"
                            FontSize="{TemplateBinding FontSize}"
                            Foreground="White"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Aggregated ingredients list -->
        <Border
            Grid.Row="1"
            Grid.ColumnSpan="3"
            Margin="20"
            Background="#a1000000"
            CornerRadius="25">
            <ScrollViewer
                VerticalScrollBarVisibility="Auto"
                Background="#00000000"
                FontSize="20"
                x:Name="ScrollViewer">
                <StackPanel
                    x:Name="IngredientsStackPanel"
                    Margin="10"/>
            </ScrollViewer>
        </Border>

    </Grid>
</Page>
