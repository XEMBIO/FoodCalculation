<Page x:Class="FoodCalculation.Views.IngredientPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="IngredientPage">

    <Grid>

        <Grid.Background>
            <LinearGradientBrush>
                <GradientStop Color="#006ba9" Offset="0"/>
                <GradientStop Color="#001a4a" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Dish name title -->
        <Label
            Grid.Row="0"
            Grid.Column="1"
            Content="Ingredients"
            Margin="20"
            VerticalContentAlignment="Center"
            HorizontalContentAlignment="Center"
            FontSize="35"
            FontWeight="Bold"
            x:Name="PageTitle"
            Foreground="White"/>

        <!-- Back button -->
        <Button
            Grid.Row="0"
            Grid.Column="2"
            Margin="20"
            Background="#ff0000"
            BorderThickness="4"
            Content="Zurueck"
            FontSize="20"
            Click="BackButton_Click"
            Foreground="White"
            x:Name="BackButton">
            <Button.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <ThicknessAnimation Storyboard.TargetName="BackButton" Storyboard.TargetProperty="Margin" To="15" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetName="BackButton" Storyboard.TargetProperty="FontSize" By="2" Duration="0:0:0.2" FillBehavior="HoldEnd"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <ThicknessAnimation Storyboard.TargetName="BackButton" Storyboard.TargetProperty="Margin" To="20" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetName="BackButton" Storyboard.TargetProperty="FontSize" By="-2" Duration="0:0:0.2" FillBehavior="Stop"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Button.Triggers>
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="#a1000000" CornerRadius="25">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Number of people input -->
        <Border
            Grid.Row="0"
            Grid.Column="0"
            CornerRadius="20"
            Background="#a1000000"
            Margin="30,60,3,0">
            <TextBox
                Background="Transparent"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                PreviewTextInput="NumberTextBox_PreviewInput"
                Foreground="White"
                BorderThickness="0"
                Margin="5"
                x:Name="AmountPeopleTextBox"/>
        </Border>

        <!-- Refresh / calculate button -->
        <Button
            Grid.Row="0"
            Grid.Column="1"
            Width="60"
            Margin="2,60,0,0"
            HorizontalAlignment="Left"
            Click="CalculateButton_Click"
            x:Name="CalculateButton">
            <Button.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <ThicknessAnimation Storyboard.TargetName="CalculateButton" Storyboard.TargetProperty="Margin" To="0,58,-2,-2" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetName="CalculateButton" Storyboard.TargetProperty="Width" To="65" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetName="CalculateButton" Storyboard.TargetProperty="FontSize" By="2" Duration="0:0:0.2" FillBehavior="HoldEnd"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <ThicknessAnimation Storyboard.TargetName="CalculateButton" Storyboard.TargetProperty="Margin" To="2,60,0,0" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetName="CalculateButton" Storyboard.TargetProperty="Width" To="60" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetName="CalculateButton" Storyboard.TargetProperty="FontSize" By="-2" Duration="0:0:0.2" FillBehavior="Stop"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Button.Triggers>
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="#a1000000" CornerRadius="20">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Left panel: base ingredient list (per person) -->
        <Border
            Grid.Row="1"
            Grid.RowSpan="2"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            CornerRadius="25"
            Background="#a1000000"
            Margin="30">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="7" x:Name="IngredientsPanel"/>
            </ScrollViewer>
        </Border>

        <!-- Right panel: calculated amounts -->
        <Border
            Grid.Row="1"
            Grid.RowSpan="2"
            Grid.Column="1"
            Margin="180,30,30,30"
            Background="Transparent">
            <ScrollViewer Margin="7" VerticalScrollBarVisibility="Auto" x:Name="IngredientMenu">
                <StackPanel x:Name="IngredientAmountPanel"/>
            </ScrollViewer>
        </Border>

        <!-- Confirm button: adds scaled ingredients to the shopping list -->
        <Button
            Grid.Row="1"
            Grid.Column="2"
            Margin="15,20"
            Background="#00ff00"
            Content="Bestaetigen"
            FontSize="20"
            Click="DoneButton_Click"
            Foreground="White"
            x:Name="DoneButton">
            <Button.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <ThicknessAnimation Storyboard.TargetName="DoneButton" Storyboard.TargetProperty="Margin" To="15" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetName="DoneButton" Storyboard.TargetProperty="FontSize" By="2" Duration="0:0:0.2" FillBehavior="HoldEnd"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <ThicknessAnimation Storyboard.TargetName="DoneButton" Storyboard.TargetProperty="Margin" To="20" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetName="DoneButton" Storyboard.TargetProperty="FontSize" By="-2" Duration="0:0:0.2" FillBehavior="Stop"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Button.Triggers>
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="#a1000000" CornerRadius="25">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

    </Grid>
</Page>
